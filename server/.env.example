PORT=3001
MONGODB_URI=mongodb://localhost:27017/kachkivun
JWT_SECRET=your-secret-key-change-in-production
# Access tokens are short-lived; refresh tokens are stored as hashed DB sessions + httpOnly cookie.
# ACCESS_TOKEN_TTL=15m
# REFRESH_TOKEN_DAYS=30

# Rate limits (per IP). Auth routes: request-otp, verify-otp, login, register.
# AUTH_RATE_LIMIT_MAX=5
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# API_RATE_LIMIT_MAX=100
# API_RATE_LIMIT_WINDOW_MS=900000
# Auto-promote this email to admin on OTP login (also: npm run promote-admin)
# ADMIN_EMAIL=admin@your-domain.example
OPENAI_API_KEY=
# Lifetime OpenAI token cap per user (sum of logged usage). Omit = unlimited.
# DEFAULT_USER_TOKEN_CAP=200000
# AI_MATCH_MODEL=gpt-4o
# AI_REPORT_MODEL=gpt-4o  (full report uses a slightly better model)
# AI_REPORT_TEMPERATURE=0.25
# Estimated USD per 1M tokens (for admin cost dashboard)
# AI_PRICE_INPUT_PER_1M=2.5
# AI_PRICE_OUTPUT_PER_1M=10

# Production (subdomain deploy): frontend origin for CORS + link on GET /
# FRONTEND_URL=https://app.your-domain.example
# ALLOWED_ORIGINS=https://app.your-domain.example

# ── Payments ──────────────────────────────────────────────────────────────────
# PAYMENTS_PROVIDER: "mock" (dev/test — grants without charging) or "grow" (real).
# mock is BLOCKED in production (NODE_ENV=production) so you can't give away paid features.
PAYMENTS_PROVIDER=mock
# Grow / Meshulam (משולם) — Israeli processor (שקלים, Bit, חשבונית). Fill from their dashboard:
# GROW_ENV=test            # "test" (sandbox) or "prod"
# GROW_PAGE_CODE=
# GROW_USER_ID=
# GROW_API_KEY=

# נתיב אופציונלי לקטלוג תפקידים (JSON). ברירת מחדל: server/data/idf-roles-preference-catalog.json
# IDF_ROLES_CATALOG_PATH=

# ── אימייל OTP (אופציונלי בפיתוח) ─────────────────────────────────────────
# בלי השלושה למטה — לא נשלח מייל; הקוד מודפס ללוג השרת בלבד (לא נשלח לממשק).
#
# דוגמה Gmail (לא "קישור" — רק קוד 6 ספרות במייל):
#   1. חשבון Google → אבטחה → אימות דו-שלבי → סיסמאות לאפליקציות → צרו סיסמה לאפליקציה.
#   2. מלאו:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   # 16 תווים ללא רווחים או עם — שניהם עובדים
# SMTP_FROM=קח כיוון <you@gmail.com>  # עדיף אותה כתובת כמו SMTP_USER (או alias מוגדר ב-Gmail)
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# FRONTEND_URL=https://app.mike.haddad.co.il
# ALLOWED_ORIGINS=https://app.mike.haddad.co.il

# נתיב אופציונלי לקטלוג תפקידים (JSON). ברירת מחדל: server/data/idf-roles-preference-catalog.json
# IDF_ROLES_CATALOG_PATH=

# ── אימייל OTP (אופציונלי בפיתוח) ─────────────────────────────────────────
# בלי השלושה למטה — לא נשלח מייל; הקוד מודפס ללוג השרת ובפיתוח גם ב-JSON (devCode).
#
# דוגמה Gmail (לא "קישור" — רק קוד 6 ספרות במייל):
#   1. חשבון Google → אבטחה → אימות דו-שלבי → סיסמאות לאפליקציות → צרו סיסמה לאפליקציה.
#   2. מלאו:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   # 16 תווים ללא רווחים או עם — שניהם עובדים
# SMTP_FROM=על מדים <you@gmail.com>  # עדיף אותה כתובת כמו SMTP_USER (או alias מוגדר ב-Gmail)
#
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
